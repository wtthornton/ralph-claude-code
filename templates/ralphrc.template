# .ralphrc - Ralph project configuration
# Generated by: ralph enable
# Documentation: https://github.com/frankbria/ralph-claude-code
#
# This file configures Ralph's behavior for this specific project.
# Values here override global Ralph defaults.
# Environment variables override values in this file.

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================

# Project name (used in prompts and logging)
PROJECT_NAME="${PROJECT_NAME:-my-project}"

# Project type: javascript, typescript, python, rust, go, unknown
PROJECT_TYPE="${PROJECT_TYPE:-unknown}"

# =============================================================================
# LOOP SETTINGS
# =============================================================================

# Maximum API calls per hour (rate limiting)
MAX_CALLS_PER_HOUR=200

# Maximum tokens per hour (0 = disabled) — Issue #223
# Tracks cumulative input+output tokens across all calls in the hour window
# Example: 500000 limits to ~500K tokens/hour regardless of call count
MAX_TOKENS_PER_HOUR=0

# Timeout for each Claude Code invocation (in minutes)
# When timeout is reached, the loop logs the event and continues to the next iteration
CLAUDE_TIMEOUT_MINUTES=15

# Output format: json (structured) or text (legacy)
CLAUDE_OUTPUT_FORMAT="json"

# =============================================================================
# TOOL PERMISSIONS
# =============================================================================
#
# Tool permissions are owned by the agent file, not .ralphrc.
#
#   - Tool-type allowlist: `tools:` block in .claude/agents/ralph.md
#   - Bash sub-command blocklist: `disallowedTools:` block in
#     .claude/agents/ralph.md
#   - Hard-coded destructive bash patterns (rm -rf, git reset --hard,
#     git clean, etc.): blocked by .claude/hooks/validate-command.sh
#   - .ralph/ + .claude/ + .ralphrc write protection: enforced by
#     .claude/hooks/protect-ralph-files.sh
#
# Edit those files to change permissions. The historical ALLOWED_TOOLS
# variable here is no longer honored (see MIGRATING.md and ADR
# docs/decisions/0006-delete-legacy-mode.md).

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# Enable session continuity (maintain context across loops)
SESSION_CONTINUITY=true

# Session expiration time in hours (start fresh after this time)
SESSION_EXPIRY_HOURS=24

# =============================================================================
# TASK BACKEND
# =============================================================================

# Task backend: "file" (default) reads from .ralph/fix_plan.md
#               "linear" — Claude picks tasks via the Linear MCP plugin (OAuth)
# Switching to "linear" requires RALPH_LINEAR_PROJECT below and the Linear MCP
# plugin enabled in your Claude Code session.
RALPH_TASK_SOURCE="file"

# Linear project name (required when RALPH_TASK_SOURCE=linear)
# Must exactly match the project name in your Linear workspace.
# RALPH_LINEAR_PROJECT="Ralph Continuous Coding"

# Linear team name (optional — used in log messages only)
# RALPH_LINEAR_TEAM="TappsCodingAgents"

# =============================================================================
# TASK SOURCES (legacy import — separate from RALPH_TASK_SOURCE)
# =============================================================================

# Where to import tasks from (comma-separated)
# Options: local, beads, github
TASK_SOURCES="local"

# GitHub label for task filtering (when github is in TASK_SOURCES)
GITHUB_TASK_LABEL="ralph-task"

# Beads filter for task import (when beads is in TASK_SOURCES)
BEADS_FILTER="status:open"

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================

# Open circuit after N loops with no file changes
CB_NO_PROGRESS_THRESHOLD=3

# Open circuit after N loops with the same error
CB_SAME_ERROR_THRESHOLD=5

# Open circuit if output declines by more than N percent
CB_OUTPUT_DECLINE_THRESHOLD=70

# Permission denial threshold — denials are deterministic, trip fast (upstream #101)
# Opens circuit after N consecutive loops with permission denials
CB_PERMISSION_DENIAL_THRESHOLD=2

# Auto-recovery: cooldown before retry (minutes, 0 = immediate)
CB_COOLDOWN_MINUTES=30

# Auto-reset circuit breaker on startup (bypasses cooldown)
# WARNING: Reduces circuit breaker safety for unattended operation
CB_AUTO_RESET=false

# =============================================================================
# MODEL ROUTING (PER-TASK TYPE + QA ESCALATION)
# =============================================================================
#
# Task-type based routing with QA failure escalation (lib/complexity.sh).
# When enabled, build_claude_command picks models based on task type and
# QA failure history instead of always using CLAUDE_MODEL above.
#
# Routing logic:
#   - docs/tools (lookups, audits, reports): → haiku (~1/5 sonnet cost)
#   - code (implementation, tests, fixes): → sonnet (floor, always)
#   - arch (design, research, migration): → opus
#   - QA escalation: if task fails QA 3+ times in a row, → opus (safety net)
#
# Default: true (cost + reliability). Set false to keep all calls on CLAUDE_MODEL.
# Per-iteration decisions are appended to .ralph/.model_routing.jsonl
# (includes task_type and reason fields for observability).
RALPH_MODEL_ROUTING_ENABLED=true

# Model overrides (deprecated; kept for compatibility).
# Task-type routing supersedes these. Set to empty to use defaults.
RALPH_MODEL_TRIVIAL=haiku
RALPH_MODEL_ROUTINE=sonnet
RALPH_MODEL_COMPLEX=sonnet
RALPH_MODEL_ARCH=opus

# Fallback model when routing is disabled OR the next task text is empty.
RALPH_DEFAULT_MODEL=sonnet

# =============================================================================
# LOG ROTATION
# =============================================================================

# Maximum ralph.log file size before rotation (in MB)
LOG_MAX_SIZE_MB=10

# Number of rotated log files to keep (ralph.log.1, ralph.log.2, ...)
LOG_MAX_FILES=5

# Maximum claude_output_*.log files to keep (oldest deleted first)
LOG_MAX_OUTPUT_FILES=20

# =============================================================================
# DRY-RUN MODE
# =============================================================================

# Preview loop execution without making API calls
# Also activatable via: ralph --dry-run
DRY_RUN=false

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

# Model to use for Ralph loops (default: uses Claude Code's default)
# Examples: claude-sonnet-4-6, claude-opus-4-7
# CLAUDE_MODEL=""

# Effort level for Ralph loops. "low" reduces output tokens ~20-40% for routine tasks.
# Agent definition defaults to "medium" — override here to reduce cost.
# Options: low, medium, high
CLAUDE_EFFORT="low"

# Auto-update Claude CLI at startup (checks npm registry, attempts npm update -g)
# Recommended: true for local workstations and home servers (keeps CLI current automatically)
# Recommended: false for Docker containers (version is pinned at image build, container is ephemeral)
# Also set false for air-gapped environments without npm registry access
CLAUDE_AUTO_UPDATE=true

# Minimum Claude CLI version required
# Ralph always invokes `claude --agent <name>`, which requires CLI v2.1+.
CLAUDE_MIN_VERSION="2.1.0"

# Enable verbose logging
RALPH_VERBOSE=false

# Agent name (matches a definition file under .claude/agents/<name>.md).
# Ralph always uses agent mode — there is no legacy `-p` fallback.
RALPH_AGENT_NAME="ralph"

# Custom prompt file (relative to .ralph/)
# PROMPT_FILE="PROMPT.md"

# Custom fix plan file (relative to .ralph/)
# FIX_PLAN_FILE="@fix_plan.md"

# Custom agent file (relative to .ralph/)
# AGENT_FILE="@AGENT.md"

# =============================================================================
# PARALLELISM (v1.1.0 Phase 4 — Experimental)
# =============================================================================

# Enable agent teams for parallel execution
# WARNING: Experimental feature. Requires Claude Code v2.1.32+
# Known limitations:
#   - No session resumption with in-process teammates
#   - Split panes not supported in VS Code terminal or Windows Terminal
#   - Requires tmux or iTerm2 for split pane display
RALPH_ENABLE_TEAMS=false
RALPH_MAX_TEAMMATES=3

# Background testing (independent of teams)
RALPH_BG_TESTING=false

# Keep tmux monitor panes alive after loop exits (default: false)
# When true, tail -f and status monitor remain after the loop finishes
KEEP_MONITOR_AFTER_EXIT=false

# Teammate display mode: "in-process" | "tmux" | "auto"
# "tmux" recommended for Ralph (already uses tmux for monitoring)
RALPH_TEAMMATE_MODE="tmux"

# =============================================================================
# PLAN OPTIMIZATION (PLANOPT epic)
# =============================================================================

# Disable automatic plan optimization on session start
# When true, fix_plan.md is never reordered by the optimizer
RALPH_NO_OPTIMIZE=false

# Disable ralph-explorer resolution of vague tasks (tasks with no file paths)
# When true, tasks without explicit file references are left as-is
RALPH_NO_EXPLORER_RESOLVE=false

# =============================================================================
# Linear cache-locality optimizer (TAP-589 LINOPT epic)
# =============================================================================
# Only active when RALPH_TASK_SOURCE=linear. Fires at
# session start as a background job: scores open issues by Jaccard overlap
# with the last-completed file set + import-graph dependency demotion, writes
# the best candidate ID to .ralph/.linear_next_issue. The runtime build_loop_context()
# reads this and injects "LOCALITY HINT: <ID>" into Claude's system prompt.

# Disable the entire optimizer (no API calls, no hint file written)
RALPH_NO_LINEAR_OPTIMIZE=false

# Skip phase 2 dependency demotion (still does locality scoring)
# When true, candidates that import another open issue's files are NOT demoted
RALPH_NO_DEP_DEMOTE=false

# Max issues fetched and scored per optimizer run
RALPH_OPTIMIZER_FETCH_LIMIT=20

# Max ralph-explorer (Haiku) fallback calls per optimizer session
# Used only for top-3 priority issues with no body paths
RALPH_OPTIMIZER_EXPLORER_MAX=3

# Per-session telemetry is written to .ralph/metrics/linear_optimizer_YYYY-MM.jsonl
# (one JSONL line per session, monthly rotation). Inspect via:
#   jq -s 'group_by(.fallback_reason) | map({reason:.[0].fallback_reason,count:length})' \
#     .ralph/metrics/linear_optimizer_*.jsonl
# Run optimizer manually: `ralph --optimize-linear`

# Maximum vague tasks to resolve per optimization run
# Caps explorer calls to stay within the ContextManager visible window
RALPH_MAX_EXPLORER_RESOLVE=5

# =============================================================================
# CONTEXT MANAGEMENT (Phase 14)
# =============================================================================

# Enable progressive context loading to reduce token usage per iteration
# When enabled, only the current epic and next N unchecked items are injected into the prompt.
# Saves 200-500 tokens/loop on plans with more than RALPH_MAX_PLAN_ITEMS unchecked tasks.
RALPH_PROGRESSIVE_CONTEXT=true

# Maximum unchecked plan items to include in progressive context
RALPH_MAX_PLAN_ITEMS=10

# =============================================================================
# COST OPTIMIZATION (Phase 14)
# =============================================================================

# Prompt cache optimization — structure prompts for maximum cache hits
# RALPH_PROMPT_CACHE_ENABLED=false

# Cost budget in USD (0 = no budget limit)
# RALPH_COST_BUDGET_USD=0

# =============================================================================
# OPENTELEMETRY EXPORT (Phase 14)
# =============================================================================

# OTLP HTTP endpoint for trace export (e.g., http://localhost:4318/v1/traces)
# RALPH_OTLP_ENDPOINT=""

# Enable OTLP trace export to external backend
# RALPH_OTLP_EXPORT_ENABLED=false

# Monthly cost budget in USD (0 = disabled, triggers alert at 80% by default)
# RALPH_COST_BUDGET_USD=0

# =============================================================================
# MONOREPO SUPPORT (Issue #163)
# =============================================================================
# Comma-separated list of service directories
# MONOREPO_SERVICES=""
# Root directory containing services (relative to project root)
# MONOREPO_ROOT="services/"

# =============================================================================
# BEADS INTEGRATION (Issue #87)
# =============================================================================
# Beads project for scoped queries
# BEADS_PROJECT=""
