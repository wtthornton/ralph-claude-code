{
  "$schema": "https://raw.githubusercontent.com/frankbria/ralph-claude-code/main/schemas/ralph-config.schema.json",
  "projectName": "my-project",
  "projectType": "unknown",
  "maxCallsPerHour": 100,
  "timeoutMinutes": 15,
  "outputFormat": "json",
  "sessionContinuity": true,
  "sessionExpiryHours": 24,
  "cbNoProgressThreshold": 3,
  "cbSameErrorThreshold": 5,
  "cbOutputDeclineThreshold": 70,
  "cbCooldownMinutes": 30,
  "cbAutoReset": false,
  "logMaxSizeMb": 10,
  "logMaxFiles": 5,
  "logMaxOutputFiles": 20,
  "dryRun": false,
  "claudeAutoUpdate": true,
  "verbose": false,
  "agentName": "ralph",
  "enableTeams": false,
  "maxTeammates": 3,
  "bgTesting": false,
  "teammateMode": "tmux",
  "notifications": {
    "enabled": false,
    "os": true,
    "sound": false,
    "webhookUrl": ""
  },
  "metrics": {
    "enabled": true,
    "retentionDays": 90
  },
  "backup": {
    "enabled": true,
    "maxBackups": 10
  },
  "github": {
    "autoCloseIssues": false,
    "taskLabel": "ralph-task"
  },
  "sandbox": {
    "enabled": false,
    "required": false,
    "cpuLimit": "2",
    "memoryLimit": "4g",
    "timeoutMinutes": 60,
    "networkIsolation": false
  }
}
