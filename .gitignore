# Ralph generated files (inside .ralph/ subfolder)
.ralph/.call_count
.ralph/.last_reset
.ralph/.exit_signals
.ralph/status.json
.ralph/.ralph_session
.ralph/.ralph_session_history
.ralph/.claude_session_id
.ralph/.response_analysis
.ralph/.circuit_breaker_state
.ralph/.circuit_breaker_history
.ralph/.json_parse_result
.ralph/.last_output_length
.ralph/.upgrade-backups/

# Ralph logs and generated docs
.ralph/logs/*
!.ralph/logs/.gitkeep
.ralph/docs/generated/*
!.ralph/docs/generated/.gitkeep

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (experimental, not committed)
.claude/settings.local.json

# Claude Code worktrees (agent isolation)
.claude/worktrees/

# Claude Code agent memory (project-scoped)
.claude/agent-memory/
.claude/agent-memory-local/

# Ralph backup directories (created by migration)
.ralph_backup_*

# Version manifest (build artifact — generated by generate_version_manifest.sh)
version.json

# Ralph metrics (Phase 8)
.ralph/metrics/

# Ralph backups (Phase 8)
.ralph/backups/

# Ralph GitHub issue state (Phase 10)
.ralph/.github_issue.json
.ralph/.github_issue_assessment.json
.ralph/batch_results.json

# SDK virtual environment (Phase 6)
sdk/.venv/
sdk/*.egg-info/
sdk/dist/
sdk/build/

# Python testing cache
.pytest_cache/
